# Copy to `.env` and fill in as needed. All values are optional:
# without an ANTHROPIC_API_KEY the agent runs in deterministic fallback mode.

# --- LLM (optional) ---
# Set this to enable the Claude-powered conversation path.
ANTHROPIC_API_KEY=
# Model id and generation settings.
MODEL_NAME=claude-opus-4-8
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# --- Pharmacy directory API ---
PHARMACY_API_URL=https://67e14fb758cc6bf785254550.mockapi.io/pharmacies
API_TIMEOUT_SECONDS=10

# --- Business rules ---
# Monthly Rx count at/above which a pharmacy is treated as "high volume".
HIGH_RX_VOLUME_THRESHOLD=100

# --- Simulation ---
# Mock caller ID used on "call start". Try +1-555-123-4567 (recognised) or a
# number not in the directory (unrecognised flow).
MOCK_CALLER_PHONE=+1-555-123-4567

# --- Logging ---
LOG_LEVEL=INFO
